{% if date %}
<time datetime="{{ date | getSitemapDate }}" data-updated="true">
  <time class="entry-date" datetime="{{ date | getSitemapDate }}">
    <span class="text-textColor font-ui font-medium text-md md:text-xl uppercase"> {{ date | displayDateOnly }} </span>
  </time>
</time>
{% endif %}
{% if lastUpdated and not (date | isSameDay(lastUpdated)) %}
<time class="entry-date" datetime="{{ lastUpdated | getSitemapDate }}">
  <span class="text-textColor font-ui font-medium text-md md:text-xl uppercase">UPDATED: {{ lastUpdated | displayDateOnly }}</span>
</time>
{% endif %}
