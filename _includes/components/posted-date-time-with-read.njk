{% if date %} {% set showUpdated = lastUpdated and (lastUpdated | htmlDateString) != (date |
htmlDateString) %}
<time datetime="{{ date | getSitemapDate }}" data-updated="true">
  <time class="entry-date" datetime="{{ date | getSitemapDate }}">
    <span class="text-textColor font-ui font-medium text-md md:text-xl uppercase">
      {{ date | displayDateOnly }}
    </span>
  </time>
</time>
<!-- Reading Time -->
<span class="text-textColor font-ui font-medium text-md md:text-xl uppercase">
  {{ helpers.getReadingTime(content) }} MIN READ
</span>
{% if showUpdated %}
<time class="entry-date updated-date" datetime="{{ lastUpdated | htmlDateString }}">
  <span class="text-textColor font-ui font-medium text-md md:text-xl uppercase">
    Last Updated: {{ lastUpdated | readableDate }}
  </span>
</time>
{% endif %} {% endif %}
